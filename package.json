{
  "name": "sequential-thinking-cli",
  "version": "0.2.3",
  "description": "AI-first sequential thinking CLI with guided step progression, convergence control, replay, and export.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "sthink": "dist/cli/index.js"
  },
  "keywords": [
    "cli",
    "agent",
    "ai",
    "sequential-thinking",
    "reasoning"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\"",
    "verify": "pnpm typecheck && pnpm test && pnpm build && node scripts/verify.mjs"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
